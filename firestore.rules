rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email == "csabanagy34@gmail.com";
    }

    // A nyilvános weboldal ezeket a tartalmakat olvassa.
    // Írni, módosítani és törölni kizárólag az adminfiók tud.
    match /events/{id}     { allow read: if true; allow write: if isAdmin(); }
    match /performers/{id} { allow read: if true; allow write: if isAdmin(); }
    match /albums/{id}     { allow read: if true; allow write: if isAdmin(); }
    match /photos/{id}     { allow read: if true; allow write: if isAdmin(); }
    match /videos/{id}     { allow read: if true; allow write: if isAdmin(); }
    match /sponsors/{id}   { allow read: if true; allow write: if isAdmin(); }
    match /tickets/{id}    { allow read: if true; allow write: if isAdmin(); }
    match /settings/{id}   { allow read: if true; allow write: if isAdmin(); }
    match /pages/{id}      { allow read: if true; allow write: if isAdmin(); }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
